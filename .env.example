# AgentHive Environment Example
# Copy to .env for local development. Never commit real secrets.

PROJECT_NAME=AgentHive
APP_ENV=development
APP_DEBUG=true

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database
POSTGRES_DB=agenthive
POSTGRES_USER=agenthive
POSTGRES_PASSWORD=agenthive
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://agenthive:agenthive@postgres:5432/agenthive

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=agenthive
MINIO_SECRET_KEY=agenthive123
MINIO_BUCKET=agenthive-files
MINIO_SECURE=false

# Ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_DEFAULT_MODEL=llama3.1

# LLM Providers - optional
GEMINI_API_KEY=
OPENAI_API_KEY=
HUGGINGFACE_API_KEY=
GROQ_API_KEY=
CUSTOM_LLM_BASE_URL=
CUSTOM_LLM_API_KEY=

# Default Model Policy
DEFAULT_PRIMARY_PROVIDER=gemini
DEFAULT_SECONDARY_PROVIDER=ollama
DEFAULT_FALLBACK_ORDER=gemini,ollama,huggingface,groq,openai
DEFAULT_MAX_INPUT_TOKENS=12000
DEFAULT_MAX_OUTPUT_TOKENS=2048
DEFAULT_LLM_TIMEOUT_SECONDS=60

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
ENABLE_OTEL=true
OTEL_SERVICE_NAME=agenthive-backend
LOKI_URL=http://loki:3100

# Security
SECRET_KEY=change-this-in-production
ENCRYPTION_KEY=change-this-32-byte-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
